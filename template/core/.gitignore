# Secrets & env
.env
.env.*
!.env.example
*.pem
*.key

# Dependencies / build output (uncomment per stack)
# node_modules/
# dist/
# build/
# __pycache__/
# .venv/
# target/

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/

# Generated quality artifacts. Whitelist shape on purpose: a directory-level
# ignore (testing-reports/) would make the shipped README un-commitable.
testing-reports/*
!testing-reports/README.md
test-results/

# Logs
*.log
